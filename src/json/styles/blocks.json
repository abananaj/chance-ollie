{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "styles": {
    "blocks": {
      
      "chance/cover-card": {
        "elements": {
          "link": { "color": { "text": "var:preset|color|white" } }
        }
      },
      "core/accordion": {
        "typography": {
          "fontFamily": "var:preset|font-family|space-grotesk",
          "fontSize": "var:preset|font-size|body"
        }
      },
      "core/accordion-panel": {
        "spacing": {
          "padding": {
            "top": "var:preset|spacing|30",
            "bottom": "var:preset|spacing|30",
            "left": "var:preset|spacing|30",
            "right": "var:preset|spacing|30"
          }
        }
      },
      "core/accordion-heading": {
        "color": {
          "background": "var:preset|color|dark-blue",
          "text": "var:preset|color|white"
        }
      },
      "core/accordion-item": {
        "spacing": {
          "blockGap": "0px"
        }
      },
      "core/avatar": {
        "border": {
          "radius": {
            "topLeft": "var:preset|border-radius|medium",
            "topRight": "var:preset|border-radius|medium",
            "bottomLeft": "var:preset|border-radius|medium",
            "bottomRight": "var:preset|border-radius|medium"
          }
        }
      },
      "core/button": {
        "color": {
          "background": "var:preset|color|dark-blue",
          "text": "var:preset|color|white"
        },
        "typography": {
          "fontFamily": "var:preset|font-family|space-grotesk",
          "fontWeight": "400",
          "fontSize": "var:preset|font-size|body",
          "textDecoration": "none"
        },
        ":hover": {
          "color": {
            "background": "var:preset|color|dark-green",
            "text": "var:preset|color|white"
          }
        },
        "shadow": "var:preset|shadow|button",
        "css": "transition: all 0.3s ease; &:hover { transition: all 0.3s ease; transform: translateY(-2px);}",
        "variations": {
          "outline": {
            "color": {
              "background": "transparent",
              "text": "var:preset|color|black"
            },
            "border": {
              "color": "var:preset|color|black",
              "style": "solid",
              "width": "2px"
            }
          },
          "no-style": {
            "color": { "background": "transparent" },
            "border": {
              "width": "0px"
            }
          }
        }
      },
      "core/buttons": {
        "spacing": {
          "blockGap": "var:preset|spacing|30"
        }
      },
      "core/columns": {
        "spacing": {
          "blockGap": "var:preset|spacing|40"
        }
      },
      "core/comment-author-name": {
        "typography": {
          "fontFamily": "var:preset|font-family|gabarito"
        }
      },
      "core/comment-content": {
        "typography": { "fontSize": "var:preset|font-size|small" }
      },
      "core/comment-date": {
        "color": { "text": "var:preset|color|secondary" },
        "elements": {
          "link": { "color": { "text": "var:preset|color|secondary" } }
        },
        "typography": {
          "fontSize": "var:preset|font-size|small",
          "lineHeight": "1.5",
          "textTransform": "none"
        }
      },
      "core/comment-edit-link": {
        "typography": {
          "fontSize": "var:preset|font-size|small",
          "lineHeight": "1.6"
        }
      },
      "core/comment-reply-link": {
        "typography": {
          "fontSize": "var:preset|font-size|small",
          "lineHeight": "1.6"
        }
      },
      "core/details": {
        "typography": {
          "fontFamily": "var:preset|font-family|space-grotesk",
          "fontSize": "var:preset|font-size|body",
          "fontStyle": "normal",
          "fontWeight": "300"
        }
      },
      "core/group": {
        "spacing": {
          "padding": {
            "top": "var:preset|spacing|30",
            "bottom": "var:preset|spacing|30",
            "left": "var:preset|spacing|30",
            "right": "var:preset|spacing|30"
          },
          "blockGap": "var:preset|spacing|30"
        },
        "variations": {
          "no-padding": {
            "spacing": {
              "padding": {
                "top": "none",
                "bottom": "none",
                "left": "none",
                "right": "none"
              },
              "blockGap": "none"
            }
          }
        }
      },
      "core/heading": {
        "spacing": {
          "margin": {
            "top": "var:preset|spacing|40",
            "right": "0",
            "bottom": "var:preset|spacing|30"
          }
        },
        "variations": {
          "uppercase": {
            "typography": {
              "fontWeight": "600",
              "letterSpacing": ".02em",
              "textTransform": "uppercase"
            }
          }
        }
      },
      "core/home-link": {
        "typography": {
          "fontFamily": "var:preset|font-family|gabarito",
          "textTransform": "uppercase",
          "fontStyle": "normal",
          "fontWeight": "800",
          "fontSize": "var:preset|font-size|x-large"
        }
      },
      "core/image": {
        "shadow": "var:preset|shadow|card",
        "border": {
          "radius": {
            "topLeft": "var:preset|border-radius|medium",
            "topRight": "var:preset|border-radius|medium",
            "bottomLeft": "var:preset|border-radius|medium",
            "bottomRight": "var:preset|border-radius|medium"
          }
        },
        "variations": {
          "no-shadow": {
            "shadow": "none"
          }
        }
      },
      "core/latest-posts": {
        "typography": {
          "fontFamily": "var:preset|font-family|gabarito",
          "lineHeight": "1.8",
          "fontSize": "var:preset|font-size|large"
        }
      },
      "core/list": {
        "typography": {
          "lineHeight": "1.5",
          "fontSize": "var:preset|font-size|body"
        },
        "spacing": {
          "margin": { "top": "0", "bottom": "0" },
          "padding": { "left": "var:preset|spacing|50" }
        },
        "variations": {
          "no-style": {
            "css": "list-style: none;"
          }
        }
      },
      "core/list-item": {
        "spacing": {
          "padding": { "top": "0", "bottom": "0" },
          "margin": { "top": "0", "bottom": "0" }
        },
        "typography": { "lineHeight": "1.75" }
      },
      "core/media-text": {
        "border": {
          "radius": {
            "topLeft": "0",
            "topRight": "0",
            "bottomLeft": "0",
            "bottomRight": "0"
          }
        },
        "typography": { "fontSize": "var:preset|font-size|large" }
      },
      "core/navigation": {
        "spacing": { "blockGap": "var:preset|spacing|30" },
        "typography": {
          "fontFamily": "var:preset|font-family|space-grotesk",
          "fontStyle": "normal",
          "fontWeight": "300",
          "fontSize": "1rem"
        }
      },
      "core/navigation-link": { "css": "" },
      "core/navigation-submenu": { "css": "" },
      "core/page-list": {
        "typography": { "fontSize": "var:preset|font-size|medium" }
      },
      "core/paragraph": {
        "typography": { "lineHeight": "1.5" },
        "spacing": {
          "margin": {
            "top": "var:preset|spacing|20",
            "bottom": "var:preset|spacing|20"
          }
        },
        "variations": {
          "uppercase": {
            "typography": {
              "fontWeight": "600",
              "letterSpacing": ".01em",
              "lineHeight": "1",
              "textTransform": "uppercase"
            }
          }
        }
      },
      "core/post-author": {
        "typography": {
          "fontFamily": "var:preset|font-family|gabarito",
          "fontSize": "var:preset|font-size|medium"
        }
      },
      "core/post-author-name": {
        "typography": {
          "fontFamily": "var:preset|font-family|gabarito",
          "fontSize": "var:preset|font-size|medium"
        }
      },
      "core/post-comments-form": {
        "border": {
          "radius": {
            "topLeft": "0",
            "topRight": "0",
            "bottomLeft": "0",
            "bottomRight": "0"
          }
        },
        "typography": { "fontSize": "var:preset|font-size|body" }
      },
      "core/post-content": {
        "color": {
          "text": "var:preset|color|black",
          "background": "var:preset|color|white"
        },
        "elements": {
          "link": {
            "color": { "text": "var:preset|color|blue" },
            ":hover": {
              "color": { "text": "var:preset|color|peach" }
            }
          }
        },
        "spacing": { "blockGap": "var:preset|spacing|40" },
        "typography": { "fontSize": "var:preset|font-size|body" }
      },
      "core/post-date": {
        "typography": {
          "fontSize": "var:preset|font-size|base",
          "fontStyle": "normal",
          "fontWeight": "400",
          "lineHeight": "1.3"
        }
      },
      "core/post-excerpt": {
        "typography": {
          "fontSize": "base",
          "fontStyle": "normal",
          "fontWeight": "400"
        },
        "elements": {
          "link": {
            "color": { "text": "var:preset|color|teal" },
            ":hover": { "color": { "text": "var:preset|color|red-orange" } }
          }
        }
      },
      "core/post-featured-image": {
        "border": {
          "radius": {
            "topLeft": "var:preset|border-radius|medium",
            "topRight": "var:preset|border-radius|medium",
            "bottomLeft": "var:preset|border-radius|medium",
            "bottomRight": "var:preset|border-radius|medium"
          }
        },
        "shadow": "var:preset|shadow|card"
      },
      "core/post-terms": {
        "spacing": {
          "margin": {
            "top": "var:preset|spacing|20",
            "bottom": "var:preset|spacing|20"
          },
          "padding": { "right": "0", "left": "0" }
        },
        "elements": {
          "link": {
            "color": { "text": "var:preset|color|dark-green" },
            ":hover": { "color": { "text": "var:preset|color|red-orange" } }
          }
        },
        "typography": {
          "fontFamily": "var:preset|font-family|space-grotesk",
          "fontSize": "var:preset|font-size|base",
          "fontStyle": "normal",
          "fontWeight": "400",
          "textTransform": "uppercase",
          "letterSpacing": "2px"
        }
      },
      "core/post-time-to-read": {
        "typography": { "fontStyle": "normal", "fontWeight": "400" }
      },
      "core/post-title": {
        "typography": {
          "fontSize": "var:preset|font-size|medium",
          "fontStyle": "normal",
          "fontWeight": "600",
          "lineHeight": "1.3",
          "textDecoration": "none",
          "letterSpacing": "0.01em"
        },
        "spacing": { "margin": { "top": "0", "bottom": "0" } },
        "elements": {
          "link": {
            "color": {
              "text": "var:preset|color|dark-blue"
            },
            ":hover": {
              "color": {
                "text": "var:preset|color|red-orange"
              }
            }
          }
        },

        "css": ""
      },
      "core/pullquote": {
        "css": "margin:auto;max-width: 45ch;& :where(cite) { display: block; font-weight:300; }",
        "spacing": {
          "padding": {
            "top": "var:preset|spacing|30",
            "right": "var:preset|spacing|30",
            "bottom": "var:preset|spacing|30",
            "left": "var:preset|spacing|30"
          }
        },
        "typography": { "fontSize": "var:preset|font-size|large" }
      },
      "core/query-title": {
        "typography": { "fontSize": "var:preset|font-size|xx-large" }
      },
      "core/quote": {
        "css": "max-width: 55ch;& :where(cite) { display: block; font-weight:300; }",
        "spacing": {
          "padding": {
            "left": "var:preset|spacing|40",
            "right": "var:preset|spacing|40"
          },
          "margin": {
            "left": "0",
            "bottom": "var:preset|spacing|30",
            "top": "var:preset|spacing|30"
          }
        },
        "typography": { "fontSize": "var:preset|font-size|large" }
      },
      "core/search": {
        "border": {
          "radius": {
            "topLeft": "0",
            "topRight": "0",
            "bottomLeft": "0",
            "bottomRight": "0"
          }
        },
        "typography": { "fontSize": "var:preset|font-size|small" }
      },
      "core/separator": {
        "spacing": {
          "margin": {
            "top": "var:preset|spacing|50",
            "bottom": "var:preset|spacing|50"
          }
        }
      },
      "core/site-tagline": {
        "typography": {
          "fontFamily": "var:preset|font-family|space-grotesk",
          "fontSize": "var:preset|font-size|medium"
        }
      },
      "core/site-title": {
        "typography": { "fontSize": "var:preset|font-size|xx-large" }
      },
      "core/social-links": {
        "spacing": {
          "blockGap": "var:preset|spacing|40"
        }
      },
      "core/tag-cloud": {
        "typography": {
          "fontFamily": "var:preset|font-family|gabarito"
        }
      },
      "core/term-name": {
        "typography": {
          "fontFamily": "var:preset|font-family|space-grotesk",
          "fontSize": "var:preset|font-size|base",
          "textTransform": "uppercase",
          "letterSpacing": "1px"
        }
      },
      "core/terms-list": {
        "css": "list-style: none;"
      },
      "core/verse": {
        "typography": {
          "lineHeight": "1.7",
          "fontFamily": "var:preset|font-family|space-grotesk"
        }
      }
    }
  }
}
