{
  "styles": {
    "blocks": {
      "core/post-content": {
        "spacing": { "blockGap": "0", "padding": { "top": "0px" } }
      },
      "core/heading": {
        "variations": {
          "uppercase": { "typography": { "letterSpacing": "1px" } }
        }
      },
      "core/button": {
        "variations": {
          "secondary-button": {
            "color": {
              "background": "var:preset|color|red-orange",
              "text": "var:preset|color|pure-white"
            }
          },
          "button-light": {
            "color": {
              "text": "var:preset|color|black",
              "background": "var:preset|color|light-blue"
            }
          },
          "button-dark": {
            "color": {
              "background": "var:preset|color|dark-blue",
              "text": "var:preset|color|pure-white"
            }
          },
          "button-brand-alt": {
            "color": { "background": "var:preset|color|goldenrod" }
          },
          "button-brand": {
            "color": {
              "background": "var:preset|color|blue",
              "text": "var:preset|color|black"
            }
          }
        }
      },
      "core/search": {
        "border": {
          "top": { "color": "var:preset|color|dark-blue", "style": "solid" },
          "right": { "color": "var:preset|color|dark-blue", "style": "solid" },
          "bottom": { "color": "var:preset|color|dark-blue", "style": "solid" },
          "left": { "color": "var:preset|color|dark-blue", "style": "solid" },
          "radius": {
            "topLeft": "var(--wp--preset--border-radius--small)",
            "topRight": "var(--wp--preset--border-radius--small)",
            "bottomLeft": "var(--wp--preset--border-radius--small)",
            "bottomRight": "var(--wp--preset--border-radius--small)"
          }
        }
      },
      "core/pullquote": {
        "color": { "background": "var:preset|color|pure-white" },
        "css": "margin:auto;\nmax-width: 45ch;\n\u0026 :where(cite) { \ndisplay: block; \nfont-weight:300; }\n"
      },
      "core/site-tagline": {
        "typography": { "fontSize": "var:preset|font-size|base" }
      },
      "core/site-title": { "typography": { "letterSpacing": "1px" } },
      "core/post-terms": { "typography": { "letterSpacing": "1px" } },
      "core/post-featured-image": {
        "border": {
          "top": { "color": "var:preset|color|black", "style": "solid" },
          "right": { "color": "var:preset|color|black", "style": "solid" },
          "bottom": { "color": "var:preset|color|black", "style": "solid" },
          "left": { "color": "var:preset|color|black", "style": "solid" },
          "radius": {
            "topLeft": "var(--wp--preset--border-radius--small)",
            "topRight": "var(--wp--preset--border-radius--small)",
            "bottomLeft": "var(--wp--preset--border-radius--small)",
            "bottomRight": "var(--wp--preset--border-radius--small)"
          }
        }
      },
      "core/tag-cloud": {
        "typography": {
          "fontFamily": "var:preset|font-family|gabarito",
          "fontStyle": "normal",
          "fontWeight": "500"
        }
      }
    },
    "elements": {
      "heading": {
        "typography": { "fontStyle": "normal", "fontWeight": "700" }
      }
    }
  },
  "settings": [],
  "isGlobalStylesUserThemeJSON": true,
  "version": 3
}
