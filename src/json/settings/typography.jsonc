							"fontStretch": "normal",
							"src": ["file:./fonts/BenchNine-Regular.woff2"],
						},
						{
							"fontFamily": "BenchNine",
							"fontWeight": "800",
							"fontStyle": "normal",
							"fontStretch": "normal",
							"src": ["file:./fonts/BenchNine-Bold.woff2"],
						},
					],
				},
			],
			"fontSizes": [
				{ "slug": "tiny", "size": "0.63rem", "name": "Tiny" },
				{ "slug": "x-small", "size": "0.75rem", "name": "X-Small" },
				{ "slug": "small", "size": "0.85rem", "name": "Small" },
				{ "slug": "base", "size": "1rem", "name": "Base" },
				{ "slug": "body", "size": "1.125rem", "name": "Body" },
				{ "slug": "medium", "size": "1.25rem", "name": "Medium" },
