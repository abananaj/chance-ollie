{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		// ➡️ EXPORT:
		"typography": {
			"customFontSize": true,
			"defaultFontSizes": false,
			"dropCap": true,
			"fluid": true,
			"fontStyle": true,
			"fontWeight": true,
			"letterSpacing": true,
			"textAlign": true,
			"textColumns": true,
			"textDecoration": true,
			"textTransform": true,
			"writingMode": true,
			"fontFamilies": [
				{
					"name": "Gabarito",
					"slug": "gabarito",
					"fontFamily": "'Gabarito', 'Gill Sans', sans-serif",
					"fontFace": [
						{
							"fontFamily": "Gabarito",
							"fontWeight": "400",
							"fontStyle": "normal",
							"fontStretch": "normal",
							"src": ["file:./fonts/Gabarito-Regular.woff2"],
						},
						{
							"fontFamily": "Gabarito",
							"fontWeight": "500",
							"fontStyle": "normal",
							"fontStretch": "normal",
							"src": ["file:./fonts/Gabarito-Medium.woff2"],
						},
						{
							"fontFamily": "Gabarito",
							"fontWeight": "600",
							"fontStyle": "normal",
							"fontStretch": "normal",
							"src": ["file:./fonts/Gabarito-SemiBold.woff2"],
						},

						{
							"fontFamily": "Gabarito",
							"fontWeight": "800",
							"fontStyle": "normal",
							"fontStretch": "normal",
							"src": ["file:./fonts/Gabarito-Bold.woff2"],
						},

						{
							"fontFamily": "Gabarito",
							"fontWeight": "800",
							"fontStyle": "normal",
							"fontStretch": "normal",
							"src": ["file:./fonts/Gabarito-ExtraBold.woff2"],
						},

						{
							"fontFamily": "Gabarito",
							"fontWeight": "800",
							"fontStyle": "normal",
							"fontStretch": "normal",
							"src": ["file:./fonts/Gabarito-Black.woff2"],
						},
					],
				},
				{
					"name": "Space Grotesk",
					"slug": "space-grotesk",
					"fontFamily": "'Space Grotesk', 'Verdana', sans-serif",
					"fontFace": [
						{
							"fontFamily": "Space Grotesk",
							"fontWeight": "300",
							"fontStyle": "normal",
							"fontStretch": "normal",
							"src": ["file:./fonts/SpaceGrotesk-Light.woff2"],
						},
						{
							"fontFamily": "Space Grotesk",
							"fontWeight": "400",
							"fontStyle": "normal",
							"fontStretch": "normal",
							"src": ["file:./fonts/SpaceGrotesk-Regular.woff2"],
						},
						{
							"fontFamily": "Space Grotesk",
							"fontWeight": "500",
							"fontStyle": "normal",
							"fontStretch": "normal",
							"src": ["file:./fonts/SpaceGrotesk-Medium.woff2"],
						},
						{
							"fontFamily": "Space Grotesk",
							"fontWeight": "600",
							"fontStyle": "normal",
							"fontStretch": "normal",
							"src": ["file:./fonts/SpaceGrotesk-SemiBold.woff2"],
						},

						{
							"fontFamily": "Space Grotesk",
							"fontWeight": "800",
							"fontStyle": "normal",
							"fontStretch": "normal",
							"src": ["file:./fonts/SpaceGrotesk-Bold.woff2"],
						},
					],
				},
				{
					"name": "BenchNine",
					"slug": "benchnine",
					"fontFamily": "'BenchNine', 'Oswald', sans-serif",
					"fontFace": [
						{
							"fontFamily": "BenchNine",
							"fontWeight": "800",
							"fontStyle": "normal",
							"fontStretch": "normal",
