{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
    // ➡️ EXPORT:
		"spacing": {
			"blockGap": true,
			"defaultSpacingSizes": true,
			"customSpacingSize": true,
			"margin": true,
			"padding": true,
			"units": ["px", "em", "rem", "vh", "vw", "%", "ch"],
			"spacingScale": {
				"increment": 1.618,
				"mediumStep": 3,
				"operator": "*",
				"steps": 7,
				"unit": "rem"
			}
		}
    // END EXPORT ❌
	}
}
