        },
        "typography": {
          "textDecoration": "none"
        },
        ":hover": {
          "color": {
            "text": "var:preset|color|grenadier"
          },
          "typography": {
            "textDecoration": "underline"
          }
        },
        ":visited": {
          "color": {
            "text": "var:preset|color|dark-blue"
          }
        }
      }
    },
