{
  "styles": {
    "blocks": {
      "core/accordion-panel": {
        "spacing": { "blockGap": "var(--wp--preset--spacing--30)" },
        "border": {
          "top": { "width": "2px", "style": "solid" },
          "right": { "width": "2px", "style": "solid" },
          "bottom": { "width": "2px", "style": "solid" },
          "left": { "width": "2px", "style": "solid" }
        },
        "color": { "background": "var(--wp--preset--color--blue-grey)" }
      },
      "core/quote": {
        "spacing": {
          "margin": {
            "top": "var(--wp--preset--spacing--30)",
            "bottom": "var(--wp--preset--spacing--30)",
            "left": "var(--wp--preset--spacing--30)",
            "right": "var(--wp--preset--spacing--30)"
          },
          "padding": {
            "top": "0",
            "bottom": "var(--wp--preset--spacing--20)",
            "left": "var(--wp--preset--spacing--50)",
            "right": "0"
          }
        }
      },
      "core/image": {
        "border": {
          "radius": {
            "topLeft": "var(--wp--preset--border-radius--small)",
            "topRight": "var(--wp--preset--border-radius--small)",
            "bottomLeft": "var(--wp--preset--border-radius--small)",
            "bottomRight": "var(--wp--preset--border-radius--small)"
          }
        }
      },
      "core/accordion": { "spacing": { "blockGap": "0" } },
      "core/accordion-heading": {
        "color": { "background": "var(--wp--preset--color--black)" },
        "spacing": {
          "padding": {
            "right": "var(--wp--preset--spacing--40)",
            "left": "var(--wp--preset--spacing--40)",
            "top": "0",
            "bottom": "0"
          }
        },
        "typography": {
          "textDecoration": "none",
          "fontSize": "var(--wp--preset--font-size--large)"
        },
        "css": ""
      },
      "core/navigation-link": { "css": "" },
      "core/button": {
        "variations": {
          "button-brand": {
            "color": {
              "background": "var(--wp--preset--color--blue)",
              "text": "var(--wp--preset--color--white)"
            },
            "border": {
              "top": { "style": "solid", "width": "2px" },
              "right": { "style": "solid", "width": "2px" },
              "bottom": { "style": "solid", "width": "2px" },
              "left": { "style": "solid", "width": "2px" }
            }
          },
          "outline": {
            "border": {
              "top": { "style": "solid", "width": "2px" },
              "right": { "style": "solid", "width": "2px" },
              "bottom": { "style": "solid", "width": "2px" },
              "left": { "style": "solid", "width": "2px" }
            }
          },
          "button-brand-alt": {
            "color": { "background": "var(--wp--preset--color--light-blue)" }
          },
          "button-light": {
            "color": { "background": "var(--wp--preset--color--light-yellow)" },
            "border": {
              "top": { "width": "0px", "style": "none" },
              "right": { "width": "0px", "style": "none" },
              "bottom": { "width": "0px", "style": "none" },
              "left": { "width": "0px", "style": "none" }
            }
          },
          "button-dark": {
            "color": {
              "text": "var(--wp--preset--color--white)",
              "background": "var(--wp--preset--color--dark-blue)"
            }
          },
          "secondary-button": {
            "color": { "background": "var(--wp--preset--color--blue-grey)" }
          }
        },
        "color": { "background": "var(--wp--preset--color--dark-blue)" },
        "border": {
          "color": null,
          "style": null,
          "width": null,
          "top": {
            "color": "hsl(208, 51%, 22%)",
            "style": "solid",
            "width": "2px"
          },
          "right": {
            "color": "hsl(208, 51%, 22%)",
            "style": "solid",
            "width": "2px"
          },
          "bottom": {
            "color": "hsl(208, 51%, 22%)",
            "style": "solid",
            "width": "2px"
          },
          "left": {
            "color": "hsl(208, 51%, 22%)",
            "style": "solid",
            "width": "2px"
          },
          "radius": {
            "topLeft": "0",
            "topRight": "0",
            "bottomLeft": "0",
            "bottomRight": "0"
          }
        },
        "typography": { "textAlign": "center", "textTransform": "none" }
      },
      "core/paragraph": {
        "variations": {
          "uppercase": {
            "typography": { "fontStyle": "normal", "fontWeight": "600" }
          }
        }
      }
    },
    "elements": {
      "h1": { "typography": { "fontStyle": "normal", "fontWeight": "800" } },
      "h2": { "typography": { "fontStyle": "normal", "fontWeight": "700" } },
      "h4": { "typography": { "fontStyle": "normal", "fontWeight": "600" } },
      "h5": { "typography": { "fontStyle": "normal", "fontWeight": "600" } },
      "h6": { "typography": { "fontStyle": "normal", "fontWeight": "600" } }
    }
  },
  "settings": {
    "blocks": {
      "core/paragraph": { "typography": { "textIndent": "subsequent" } }
    },
    "color": {
      "palette": {
        "custom": [
          { "color": "#000", "name": "Color 1", "slug": "custom-color-1" }
        ]
      }
    }
  },
  "isGlobalStylesUserThemeJSON": true,
  "version": 3
}

